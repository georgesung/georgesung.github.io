                  "type": "string"
                },
                "expected_replacements": {
                  "type": "number",
                  "description": "Number of replacements expected. Defaults to 1 if not specified. Use when you want to replace multiple occurrences.",
                  "minimum": 1
                }
              },
              "required": [
                "file_path",
                "instruction",
                "old_string",
                "new_string"
